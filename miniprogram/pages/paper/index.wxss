.auth-card {
  padding-top: 28rpx;
}

.auth-tabs {
  margin-bottom: 24rpx;
}

.account-card {
  border-color: #1f2937;
  color: #ffffff;
  background: linear-gradient(135deg, #101820 0%, #263548 100%);
}

.account-card .card-title,
.account-card .muted,
.account-card .metric-label,
.account-card .metric-value {
  color: #ffffff;
}

.account-card .metric {
  background: rgba(255, 255, 255, 0.1);
}

.asset-chart {
  margin-top: 18rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.92);
}

.watch-scroll {
  width: 100%;
  margin-bottom: 18rpx;
  white-space: nowrap;
}

.watch-strip {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 6rpx;
}

.watch-chip {
  width: 196rpx;
  padding: 18rpx;
  border: 1rpx solid #d6deeb;
  border-radius: 14rpx;
  background: #ffffff;
}

.watch-chip-active {
  border-color: #d12f2f;
  background: #fff8f8;
}

.watch-name,
.watch-code {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.watch-name {
  color: #101820;
  font-size: 26rpx;
  font-weight: 700;
}

.watch-code {
  margin: 6rpx 0;
  color: #667085;
  font-size: 22rpx;
}

.quote-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}

.quote-price {
  display: block;
  color: #101820;
  font-size: 34rpx;
  font-weight: 800;
}

.kline-chart {
  border-radius: 12rpx;
  background: #ffffff;
}

.search-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 150rpx;
  gap: 12rpx;
}

.search-button {
  height: 76rpx;
  line-height: 76rpx;
}

.candidate-list {
  margin: -4rpx 0 18rpx;
  border: 1rpx solid #edf1f7;
  border-radius: 12rpx;
  overflow: hidden;
}

.candidate {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 18rpx;
  border-bottom: 1rpx solid #edf1f7;
  background: #ffffff;
  font-size: 24rpx;
}

.candidate:last-child {
  border-bottom: 0;
}

.segmented {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.type-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.segment {
  min-height: 62rpx;
  padding: 14rpx 8rpx;
  border: 1rpx solid #d6deeb;
  border-radius: 10rpx;
  color: #475467;
  text-align: center;
  font-size: 24rpx;
  background: #ffffff;
}

.segment-active,
.segment-buy-active {
  border-color: #d12f2f;
  color: #d12f2f;
  background: #fff1f1;
  font-weight: 700;
}

.segment-sell-active {
  border-color: #148f56;
  color: #148f56;
  background: #e9f8ef;
  font-weight: 700;
}

.form-grid {
  margin-top: 18rpx;
}

.match-button {
  margin-top: 14rpx;
}

.signal {
  display: inline-block;
  margin-top: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.signal-buy {
  color: #d12f2f;
  background: #fff1f1;
}

.signal-risk {
  color: #148f56;
  background: #e9f8ef;
}

.signal-hold {
  color: #475467;
  background: #eef2f7;
}

.position-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 230rpx;
  gap: 14rpx;
}

.record-tabs {
  margin-bottom: 10rpx;
}

.record-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 170rpx 62rpx;
  align-items: center;
  gap: 12rpx;
}

.cancel-button {
  min-width: 58rpx;
  padding: 0;
}
