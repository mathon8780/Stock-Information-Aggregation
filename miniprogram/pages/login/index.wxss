.login-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #101820 0%, #263548 48%, #f4f7fb 48%, #f4f7fb 100%);
}

.login-hero {
  padding: 32rpx 8rpx 56rpx;
}

.login-title {
  display: block;
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.login-subtitle {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  line-height: 1.5;
}

.login-card {
  margin-bottom: 80rpx;
  padding: 30rpx 24rpx;
}

.auth-tabs {
  margin-bottom: 24rpx;
}

.backend-field {
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}

.backend-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 132rpx;
  gap: 12rpx;
}

.backend-button {
  height: 76rpx;
  line-height: 76rpx;
}

.backend-help {
  display: block;
  margin-top: 10rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.45;
}
