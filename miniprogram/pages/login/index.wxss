.login-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #101820 0%, #263548 48%, #f4f7fb 48%, #f4f7fb 100%);
}

.login-hero {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 32rpx 8rpx 56rpx;
}

.login-copy {
  flex: 1;
  min-width: 0;
}

.login-title {
  display: block;
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.login-subtitle {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  line-height: 1.5;
}

.login-card {
  width: 100%;
  margin-bottom: 80rpx;
  padding: 30rpx 24rpx;
  overflow: hidden;
}

.auth-tabs {
  margin-bottom: 24rpx;
}

.backend-field {
  padding: 14rpx;
  border: 1rpx solid #e4e9f2;
  border-radius: 14rpx;
  background: #f8fafc;
}

.field-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.field-title-row .field-label {
  margin-bottom: 0;
}

.backend-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 116rpx;
  gap: 8rpx;
  align-items: stretch;
  width: 100%;
  overflow: hidden;
}

.backend-input,
.backend-button,
.captcha-input,
.captcha-button {
  min-width: 0;
  width: 100%;
}

.compact-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 66rpx;
  margin: 0;
  padding: 0 6rpx;
  border-radius: 10rpx;
  box-sizing: border-box;
  color: #263548;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
  overflow: hidden;
  white-space: nowrap;
}

.backend-input,
.captcha-input {
  min-height: 66rpx;
  padding: 0 16rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
}

.compact-action-disabled {
  opacity: 0.72;
  color: #263548;
  background: #eef2f7;
}

.backend-help {
  display: block;
  margin-top: 10rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.45;
}

.captcha-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 116rpx;
  gap: 8rpx;
  align-items: stretch;
  width: 100%;
  overflow: hidden;
}
