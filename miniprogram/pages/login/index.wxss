.login-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #101820 0%, #263548 48%, #f4f7fb 48%, #f4f7fb 100%);
}

.login-hero {
  padding: 32rpx 8rpx 56rpx;
}

.login-title {
  display: block;
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.login-subtitle {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  line-height: 1.5;
}

.login-card {
  margin-bottom: 80rpx;
  padding: 30rpx 24rpx;
}

.auth-tabs {
  margin-bottom: 24rpx;
}
