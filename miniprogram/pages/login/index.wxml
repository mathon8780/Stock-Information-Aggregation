<view class="page login-page">
  <view class="login-hero">
    <view class="ui-icon ui-icon-large ui-icon-inverse icon-lock"></view>
    <view class="login-copy">
      <text class="login-title">证券监视</text>
      <text class="login-subtitle">进入小程序前请先登录模拟交易用户账号</text>
    </view>
  </view>

  <view class="card login-card">
    <view class="card-title-row">
      <view class="ui-icon icon-account"></view>
      <text class="card-title">账户登录</text>
    </view>
    <view class="pill-row auth-tabs">
      <view class="pill {{mode == 'login' ? 'pill-active' : ''}}" data-mode="login" bindtap="setMode">登录账户</view>
      <view class="pill {{mode == 'create' ? 'pill-active' : ''}}" data-mode="create" bindtap="setMode">创建账户</view>
    </view>

    <block wx:if="{{mode == 'login'}}">
      <view class="field backend-field">
        <view class="field-title-row">
          <view class="ui-icon ui-icon-small icon-api"></view>
          <text class="field-label">后端 API 地址</text>
        </view>
        <view class="backend-row">
          <input class="input backend-input" value="{{apiBaseUrl}}" data-field="apiBaseUrl" bindinput="bindInput" placeholder="http://电脑IP:8000/api/v1" />
          <view class="secondary-button compact-action backend-button {{backendChecking ? 'compact-action-disabled' : ''}}" bindtap="checkBackend">测试</view>
        </view>
        <text class="backend-help">真机预览不要使用 127.0.0.1，请填写电脑局域网 IP。</text>
      </view>
      <view class="field">
        <text class="field-label">账号</text>
        <input class="input" value="{{loginOwnerName}}" data-field="loginOwnerName" bindinput="bindInput" placeholder="输入模拟交易账号" />
      </view>
      <view class="field">
        <text class="field-label">密码</text>
        <input class="input" password value="{{loginPassword}}" data-field="loginPassword" bindinput="bindInput" placeholder="输入密码" />
      </view>
      <button class="primary-button" loading="{{loginSubmitting}}" bindtap="loginPaperAccount">登录并进入</button>
    </block>

    <block wx:else>
      <view class="field backend-field">
        <view class="field-title-row">
          <view class="ui-icon ui-icon-small icon-api"></view>
          <text class="field-label">后端 API 地址</text>
        </view>
        <view class="backend-row">
          <input class="input backend-input" value="{{apiBaseUrl}}" data-field="apiBaseUrl" bindinput="bindInput" placeholder="http://电脑IP:8000/api/v1" />
          <view class="secondary-button compact-action backend-button {{backendChecking ? 'compact-action-disabled' : ''}}" bindtap="checkBackend">测试</view>
        </view>
        <text class="backend-help">真机预览不要使用 127.0.0.1，请填写电脑局域网 IP。</text>
      </view>
      <view class="field">
        <text class="field-label">账号</text>
        <input class="input" value="{{createOwnerName}}" data-field="createOwnerName" bindinput="bindInput" placeholder="创建模拟交易账号" />
      </view>
      <view class="field">
        <text class="field-label">手机号</text>
        <input class="input" type="number" value="{{createPhone}}" data-field="createPhone" bindinput="bindInput" placeholder="用于检查是否已注册" />
      </view>
      <view class="field">
        <text class="field-label">密码</text>
        <input class="input" password value="{{createPassword}}" data-field="createPassword" bindinput="bindInput" placeholder="至少 6 位" />
      </view>
      <view class="field">
        <text class="field-label">验证码</text>
        <view class="captcha-row">
          <input class="input captcha-input" value="{{createCaptchaCode}}" data-field="createCaptchaCode" bindinput="bindInput" placeholder="输入模拟验证码" />
          <view class="secondary-button compact-action captcha-button {{captchaSubmitting ? 'compact-action-disabled' : ''}}" bindtap="requestCreateCaptcha">获取</view>
        </view>
      </view>
      <button class="primary-button" loading="{{createSubmitting}}" bindtap="createPaperAccount">创建并进入</button>
    </block>
  </view>
</view>
