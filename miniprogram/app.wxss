page {
  min-height: 100%;
  background: #f3f6fb;
  color: #15202b;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  background: linear-gradient(180deg, #edf2f8 0%, #f7f9fc 260rpx, #f4f7fb 100%);
}

.page-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 22rpx;
  padding: 8rpx 2rpx;
}

.page-heading {
  flex: 1;
  min-width: 0;
}

.page-title {
  display: block;
  color: #101820;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.page-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #e4e9f2;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(16, 24, 40, 0.07);
}

.card-title {
  display: block;
  color: #101820;
  font-size: 30rpx;
  font-weight: 700;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 48rpx;
  margin-bottom: 18rpx;
}

.card-title-row .card-title {
  margin-bottom: 0;
}

.muted {
  color: #667085;
}

.ui-icon {
  position: relative;
  flex: none;
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  color: #d12f2f;
  background: #fff1f1;
  box-shadow: inset 0 0 0 1rpx rgba(209, 47, 47, 0.1);
}

.ui-icon-small {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
}

.ui-icon-large {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
}

.ui-icon-dark {
  color: #101820;
  background: #f5c451;
  box-shadow: none;
}

.ui-icon-inverse {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.14);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.18);
}

.ui-icon::before,
.ui-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  display: block;
  box-sizing: border-box;
  transform: translate(-50%, -50%);
}

.icon-dashboard::before {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  box-shadow: 16rpx 0 0 -4rpx currentColor, 0 16rpx 0 -4rpx currentColor, 16rpx 16rpx 0 -4rpx currentColor;
}

.icon-news::before {
  width: 26rpx;
  height: 28rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
}

.icon-news::after {
  width: 16rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 8rpx 0 currentColor;
}

.icon-trade::before {
  width: 28rpx;
  height: 18rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: translate(-50%, -50%) rotate(-35deg);
}

.icon-trade::after {
  width: 14rpx;
  height: 14rpx;
  border-right: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: translate(-10%, -80%) rotate(10deg);
}

.icon-account::before {
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-radius: 999rpx;
  transform: translate(-50%, -78%);
}

.icon-account::after {
  width: 28rpx;
  height: 16rpx;
  border: 4rpx solid currentColor;
  border-top-left-radius: 18rpx;
  border-top-right-radius: 18rpx;
  border-bottom: 0;
  transform: translate(-50%, 18%);
}

.icon-market::before {
  width: 28rpx;
  height: 24rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
}

.icon-market::after {
  width: 22rpx;
  height: 14rpx;
  border-right: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: translate(-42%, -42%) rotate(-18deg);
}

.icon-watch::before {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid currentColor;
  border-radius: 999rpx;
}

.icon-watch::after {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.icon-order::before {
  width: 28rpx;
  height: 24rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
}

.icon-order::after {
  width: 16rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 8rpx 0 currentColor;
}

.icon-position::before {
  width: 30rpx;
  height: 24rpx;
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
}

.icon-position::after {
  width: 20rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 -8rpx 0 currentColor, 0 8rpx 0 currentColor;
}

.icon-record::before {
  width: 26rpx;
  height: 30rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
}

.icon-record::after {
  width: 14rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 8rpx 0 currentColor;
  transform: translate(-20%, -50%);
}

.icon-filter::before {
  width: 30rpx;
  height: 4rpx;
  background: currentColor;
  box-shadow: 0 10rpx 0 currentColor, 0 -10rpx 0 currentColor;
}

.icon-filter::after {
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: currentColor;
  box-shadow: -10rpx -10rpx 0 currentColor, 10rpx 10rpx 0 currentColor;
}

.icon-lock::before {
  width: 28rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
  transform: translate(-50%, -28%);
}

.icon-lock::after {
  width: 20rpx;
  height: 18rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-top-left-radius: 14rpx;
  border-top-right-radius: 14rpx;
  transform: translate(-50%, -92%);
}

.icon-api::before {
  width: 28rpx;
  height: 18rpx;
  border-top: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
}

.icon-api::after {
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: currentColor;
  box-shadow: -14rpx 0 0 currentColor, 14rpx 0 0 currentColor;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.row-between > .card-title-row {
  margin-bottom: 0;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.metric {
  min-width: 0;
  padding: 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid #edf1f7;
  background: #f8fafc;
}

.metric-label {
  display: block;
  color: #667085;
  font-size: 22rpx;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  color: #101820;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
  word-break: break-all;
}

.metric-extra {
  display: block;
  margin-top: 6rpx;
  color: #667085;
  font-size: 22rpx;
}

.price-up {
  color: #d12f2f;
}

.price-down {
  color: #148f56;
}

.price-flat {
  color: #667085;
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pill {
  min-height: 56rpx;
  padding: 12rpx 20rpx;
  border: 1rpx solid #d6deeb;
  border-radius: 999rpx;
  color: #475467;
  background: #ffffff;
  font-size: 24rpx;
}

.pill-active {
  border-color: #d12f2f;
  color: #d12f2f;
  background: #fff1f1;
  font-weight: 700;
}

.list-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf1f7;
}

.list-item:last-child {
  border-bottom: 0;
}

.stock-name {
  display: block;
  color: #101820;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
}

.stock-code {
  display: block;
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
}

.value-right {
  text-align: right;
}

.primary-button,
.secondary-button,
.danger-button {
  height: 76rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 76rpx;
}

.primary-button {
  color: #ffffff;
  background: #d12f2f;
}

.secondary-button {
  color: #263548;
  background: #eef2f7;
}

.danger-button {
  color: #ffffff;
  background: #aa1e1e;
}

.ghost-button {
  height: 60rpx;
  border: 1rpx solid #d6deeb;
  border-radius: 10rpx;
  color: #263548;
  background: #ffffff;
  font-size: 24rpx;
  line-height: 60rpx;
}

.field {
  margin-bottom: 18rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #344054;
  font-size: 24rpx;
  font-weight: 600;
}

.input {
  width: 100%;
  min-height: 76rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d6deeb;
  border-radius: 12rpx;
  color: #101820;
  background: #ffffff;
  font-size: 28rpx;
}

.empty {
  padding: 48rpx 24rpx;
  color: #667085;
  text-align: center;
}

.chart {
  width: 100%;
  height: 320rpx;
}
