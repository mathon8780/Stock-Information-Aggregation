page {
  min-height: 100%;
  background: #f4f7fb;
  color: #15202b;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
}

.page-header {
  margin-bottom: 20rpx;
}

.page-title {
  display: block;
  color: #101820;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.page-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #e4e9f2;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(16, 24, 40, 0.06);
}

.card-title {
  display: block;
  margin-bottom: 18rpx;
  color: #101820;
  font-size: 30rpx;
  font-weight: 700;
}

.muted {
  color: #667085;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.metric {
  min-width: 0;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}

.metric-label {
  display: block;
  color: #667085;
  font-size: 22rpx;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  color: #101820;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
  word-break: break-all;
}

.metric-extra {
  display: block;
  margin-top: 6rpx;
  color: #667085;
  font-size: 22rpx;
}

.price-up {
  color: #d12f2f;
}

.price-down {
  color: #148f56;
}

.price-flat {
  color: #667085;
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pill {
  min-height: 56rpx;
  padding: 12rpx 20rpx;
  border: 1rpx solid #d6deeb;
  border-radius: 999rpx;
  color: #475467;
  background: #ffffff;
  font-size: 24rpx;
}

.pill-active {
  border-color: #d12f2f;
  color: #d12f2f;
  background: #fff1f1;
  font-weight: 700;
}

.list-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf1f7;
}

.list-item:last-child {
  border-bottom: 0;
}

.stock-name {
  display: block;
  color: #101820;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
}

.stock-code {
  display: block;
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
}

.value-right {
  text-align: right;
}

.primary-button,
.secondary-button,
.danger-button {
  height: 76rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 76rpx;
}

.primary-button {
  color: #ffffff;
  background: #d12f2f;
}

.secondary-button {
  color: #263548;
  background: #eef2f7;
}

.danger-button {
  color: #ffffff;
  background: #aa1e1e;
}

.ghost-button {
  height: 60rpx;
  border: 1rpx solid #d6deeb;
  border-radius: 10rpx;
  color: #263548;
  background: #ffffff;
  font-size: 24rpx;
  line-height: 60rpx;
}

.field {
  margin-bottom: 18rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #344054;
  font-size: 24rpx;
  font-weight: 600;
}

.input {
  width: 100%;
  min-height: 76rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d6deeb;
  border-radius: 12rpx;
  color: #101820;
  background: #ffffff;
  font-size: 28rpx;
}

.empty {
  padding: 48rpx 24rpx;
  color: #667085;
  text-align: center;
}

.chart {
  width: 100%;
  height: 320rpx;
}
