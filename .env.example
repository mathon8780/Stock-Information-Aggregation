# Application
APP_ENV=local
APP_PORT=8000
FRONTEND_PORT=3000
AUTO_SEED_DEMO_DATA=false

# Database
# Runtime uses local PostgreSQL by default. SQLite is reserved for tests.
DATABASE_URL=postgresql+psycopg://market:change_me@localhost:5432/market_agent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=market_agent
POSTGRES_USER=market
POSTGRES_PASSWORD=change_me

# QQBot
QQBOT_TARGET=configured_qqbot_default
QQBOT_WEBHOOK_URL=
QQBOT_DRY_RUN=true
QQBOT_BATCH_SIZE=10
QQBOT_MAX_RETRY=3
QQBOT_ENABLE_PRICE_ALERT=true
QQBOT_ENABLE_STRATEGY_ALERT=true
QQBOT_ENABLE_NEWS_DIGEST=true
QQBOT_ENABLE_DAILY_SUMMARY=true
QQBOT_ENABLE_JOB_FAILED_ALERT=true
PUSH_MESSAGE_ENABLED=true
PUSH_MESSAGE_DIR=C:\File\PushMessage

# Collector intervals
MARKET_SNAPSHOT_INTERVAL_SECONDS=300
WATCH_SNAPSHOT_INTERVAL_SECONDS=60
NEWS_INTERVAL_SECONDS=300
NEWS_AUTO_SYNC_ENABLED=true
NEWS_AUTO_SYNC_INTERVAL_SECONDS=300
NEWS_AUTO_SYNC_LIMIT=30
NEWS_AUTO_SIMPLIFY_LIMIT=50
ADVICE_INTERVAL_SECONDS=900
NEWS_SOURCE_REQUEST_INTERVAL_SECONDS=2

# Startup sync
# Runs once in the backend background after app startup. Full-market history is opt-in
# because it is slow and can put pressure on the free data source.
STARTUP_SYNC_ENABLED=true
STARTUP_SYNC_WATCHLIST_ENABLED=true
STARTUP_SYNC_MARKET_ENABLED=true
STARTUP_SYNC_HISTORY_ENABLED=true
STARTUP_SYNC_HISTORY_DAYS=365
STARTUP_SYNC_INTRADAY_ENABLED=true
STARTUP_SYNC_INTRADAY_TRADING_DAYS=10
STARTUP_SYNC_INTRADAY_PERIOD_MINUTES=5
STARTUP_SYNC_NEWS_ENABLED=true
STARTUP_SYNC_ANALYSIS_ENABLED=true
STARTUP_SYNC_FULL_MARKET_HISTORY_ENABLED=false
STARTUP_SYNC_FULL_MARKET_HISTORY_DAYS=365
STARTUP_SYNC_FULL_MARKET_HISTORY_BATCH_SIZE=30
STARTUP_SYNC_FULL_MARKET_HISTORY_LIMIT=

# Risk control
REQUEST_MIN_INTERVAL_SECONDS=3
FETCH_FAILURE_DOWNGRADE_THRESHOLD=3
MAX_WATCHLIST_SIZE=20

# Free data source
MARKET_DATA_PRIMARY=akshare
MARKET_DATA_FALLBACK=public_web

# Analysis
ANALYSIS_ENGINE=rule_engine
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=
NEWS_LLM_PROVIDER=deepseek
NEWS_LLM_API_KEY=
NEWS_LLM_API_BASE_URL=https://api.deepseek.com
NEWS_LLM_MODEL=deepseek-v4-flash
NEWS_LLM_TIMEOUT_SECONDS=40
NEWS_LLM_MAX_CONCURRENCY=50
# Backward-compatible aliases; NEWS_LLM_* takes precedence when set.
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
NEWSNOW_API_BASE_URL=https://newsnow.busiyi.world/api

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
